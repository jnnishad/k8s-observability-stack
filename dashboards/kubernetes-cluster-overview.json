{
  "title": "Kubernetes Cluster Overview",
  "uid": "k8s-cluster-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Cluster CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (namespace)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cluster Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\"}) by (namespace)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod Restarts (15m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total[15m])",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Nodes Ready",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})"
        }
      ]
    },
    {
      "id": 5,
      "title": "API Server 5xx Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(apiserver_request_total{code=~\"5..\"}[5m]))"
        }
      ]
    }
  ]
}